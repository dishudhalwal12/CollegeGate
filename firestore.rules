rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRecord() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserRecord() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasUserRecord() ? userRecord().data.role : null;
    }

    function isActiveUser() {
      return hasUserRecord() && userRecord().data.isActive == true;
    }

    function isAdmin() {
      return isActiveUser() && role() == "admin";
    }

    function isOwnProfile(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasAssignmentKey(data) {
      return data.assignmentKey is string && data.assignmentKey.size() > 0;
    }

    function hasHostelBlock(data) {
      return data.hostelBlock is string && data.hostelBlock.size() > 0;
    }

    function profileAssignmentKey(data) {
      return hasAssignmentKey(data)
        ? data.assignmentKey
        : hasHostelBlock(data)
          ? data.hostelBlock
          : null;
    }

    function sharesAssignmentGroup(data) {
      return hasUserRecord()
        && profileAssignmentKey(userRecord().data) != null
        && profileAssignmentKey(data) == profileAssignmentKey(userRecord().data);
    }

    function isPendingAdminRequest() {
      return request.resource.data.role == "pending"
        && request.resource.data.requestedRole == "admin";
    }

    function isImmediateAccessSignup() {
      return request.resource.data.role in ["student", "warden", "guard"]
        && request.resource.data.isActive == true
        && !request.resource.data.keys().hasAny(["requestedRole"]);
    }

    function isLegacyAssignedStudent(data) {
      return data.wardenId is string && data.wardenId == request.auth.uid;
    }

    function isLegacyAssignedWarden(userId) {
      return hasUserRecord()
        && userRecord().data.wardenId is string
        && userRecord().data.wardenId == userId;
    }

    function validSelfSignupKeys() {
      return request.resource.data.keys().hasOnly([
        "name",
        "email",
        "role",
        "requestedRole",
        "department",
        "hostelBlock",
        "assignmentKey",
        "phone",
        "isActive",
        "createdAt"
      ]);
    }

    function validSelfSignupPayload() {
      return validSelfSignupKeys()
        && request.resource.data.name is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.department is string
        && request.resource.data.hostelBlock is string
        && request.resource.data.assignmentKey is string
        && request.resource.data.phone is string
        && request.resource.data.createdAt is string
        && (
          isImmediateAccessSignup()
          || (isPendingAdminRequest() && request.resource.data.isActive == false)
        );
    }

    match /users/{userId} {
      allow create: if isOwnProfile(userId)
        && !exists(/databases/$(database)/documents/users/$(userId))
        && validSelfSignupPayload();
      allow read: if isOwnProfile(userId)
        || isAdmin()
        || (isActiveUser()
          && role() == "student"
          && resource.data.role == "warden"
          && resource.data.isActive == true
          && (
            sharesAssignmentGroup(resource.data)
            || isLegacyAssignedWarden(userId)
          ))
        || (isActiveUser()
          && role() == "warden"
          && resource.data.role == "student"
          && resource.data.isActive == true
          && (
            isLegacyAssignedStudent(resource.data)
            || sharesAssignmentGroup(resource.data)
          ));
      allow update, delete: if isAdmin();
    }

    match /outpasses/{outpassId} {
      allow read: if isActiveUser() && (
        isAdmin() ||
        role() == "guard" ||
        (role() == "student" && resource.data.studentId == request.auth.uid) ||
        (role() == "warden" && resource.data.assignedWardenId == request.auth.uid)
      );
      allow create: if isActiveUser()
        && role() == "student"
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isActiveUser() && (
        isAdmin() ||
        role() == "guard" ||
        (role() == "warden" && resource.data.assignedWardenId == request.auth.uid)
      );
    }

    match /gateLogs/{logId} {
      allow read: if isActiveUser() && (isAdmin() || role() == "guard" || role() == "warden");
      allow write: if isActiveUser() && (isAdmin() || role() == "guard");
    }

    match /systemConfig/{configId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }
  }
}
